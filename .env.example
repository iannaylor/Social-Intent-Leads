# Copy to .env for local testing only. In production these are set as
# secret env vars in the Render dashboard (render.yaml marks them sync:false
# so they're never committed to git).

ANTHROPIC_API_KEY=
RICHAPI_API_KEY=
AIRTABLE_API_KEY=
# ID of an Airtable base the AIRTABLE_API_KEY above has create/edit access
# to — can be a brand new, completely empty base. The three tables this
# app needs (Social Intent Leads, Social Intent Products, Social Intent
# Voice Profiles) are created automatically on first startup if they
# don't already exist. Find a base's ID in its URL: airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=
# Comma-separated list of API keys this backend will accept from the
# extension. Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
BACKEND_API_KEYS=
