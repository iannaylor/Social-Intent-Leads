# Copy to .env for local testing only. In production these are set as
# secret env vars in the Render dashboard (render.yaml marks them sync:false
# so they're never committed to git).

ANTHROPIC_API_KEY=
RICHAPI_API_KEY=
AIRTABLE_API_KEY=
# Comma-separated list of API keys this backend will accept from the
# extension. Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
BACKEND_API_KEYS=
